    // ══════════════════════════════════════════════════════
    function abrirTeste(id) {
      testeAtual = TESTES[id];
      faseAtual = 0;
      questaoAtual = 0;
      respostas = [];

      document.getElementById('modal-categoria').textContent = testeAtual.categoria;
      document.getElementById('modal-titulo').textContent = testeAtual.titulo;

      // Recuperar dados guardados previamente para melhorar a fluidez (UX)
      document.getElementById('f-nome').value = localStorage.getItem('psi_nome') || '';
      document.getElementById('f-idade').value = localStorage.getItem('psi_idade') || '';
      document.getElementById('f-telefone').value = localStorage.getItem('psi_telefone') || '';
      document.getElementById('f-email').value = localStorage.getItem('psi_email') || '';
      document.getElementById('f-motivo').value = ''; 

      mostrarFase(0);
      document.getElementById('modalOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function fecharModal() {
      if (faseAtual === 1) {
        mostrarToast('Por favor, finalize o teste ou utilize o botão de "Voltar" para cancelar.');
        return;
      }
      document.getElementById('modalOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    function mostrarFase(fase) {
      faseAtual = fase;
      document.querySelectorAll('.fase').forEach(f => f.classList.remove('active'));
      document.getElementById('fase-' + fase).classList.add('active');

      const btnBack = document.getElementById('btn-back');
      const btnNext = document.getElementById('btn-next');

      if (fase === 0) {
        btnBack.style.visibility = 'hidden';
        btnNext.textContent = 'Começar o teste →';
        btnNext.disabled = false;
      } else if (fase === 1) {
        btnBack.style.visibility = 'visible';
        renderQuestao();
      } else if (fase === 2) {
        btnBack.style.visibility = 'hidden';
        btnNext.textContent = '🔄 Refazer teste';
        btnNext.disabled = false;
      }
    }

    function avancarFase() {
      if (faseAtual === 0) {
        const nome = document.getElementById('f-nome').value.trim();
        const idade = document.getElementById('f-idade').value.trim();
        const telefone = document.getElementById('f-telefone').value.trim();
        const email = document.getElementById('f-email').value.trim();
        const motivo = document.getElementById('f-motivo').value.trim();

        if (!nome || !idade) { 
          mostrarToast('Por favor, preencha nome e idade.'); 
          return; 
        }

        // Armazenar localmente para evitar dupla digitação futura
        localStorage.setItem('psi_nome', nome);
        localStorage.setItem('psi_idade', idade);
        localStorage.setItem('psi_telefone', telefone);
        localStorage.setItem('psi_email', email);

        dadosAvaliado = { nome, idade, telefone, email, motivo };
        questaoAtual = 0;
        respostas = new Array(testeAtual.questoes.length).fill(null);
        mostrarFase(1);
      } else if (faseAtual === 2) {
        abrirTeste(Object.keys(TESTES).find(k => TESTES[k] === testeAtual));
      }
    }

    function voltarFase() {
      if (faseAtual === 0) return;
      if (faseAtual === 1 && questaoAtual > 0) {
        questaoAtual--;
        renderQuestao();
      } else if (faseAtual === 1 && questaoAtual === 0) {
        mostrarFase(0);
      }
    }

    // ══════════════════════════════════════════════════════
    // GESTÃO E RENDERIZAÇÃO DAS PERGUNTAS
    // ══════════════════════════════════════════════════════
    function renderQuestao() {
      const total = testeAtual.questoes.length;
      const pct = ((questaoAtual) / total * 100).toFixed(0);
      
      const progressBar = document.getElementById('progressbar');
      const progressFill = document.getElementById('progress-fill');
      
      progressFill.style.width = pct + '%';
      progressBar.setAttribute('aria-valuenow', pct);
      
      document.getElementById('progress-label').textContent = `Questão ${questaoAtual + 1} de ${total}`;

      const container = document.getElementById('questao-container');
      const opcoes = testeAtual.opcoes;
      const q = testeAtual.questoes[questaoAtual];
      const selecionado = respostas[questaoAtual];

      container.innerHTML = `
        <div class="questao-num">Questão ${questaoAtual + 1}</div>
        <div class="questao-texto">${q}</div>
        <div class="opcoes">
          ${opcoes.map((op, i) => `
            <button class="opcao-btn ${selecionado === i ? 'selected' : ''}"
              onclick="selecionarOpcao(${i})"
              role="radio"
              aria-checked="${selecionado === i ? 'true' : 'false'}">
              <span class="opcao-bullet">${String.fromCharCode(65 + i)}</span>
              ${op.label}
            </button>
          `).join('')}
        </div>
      `;

      const btnNext = document.getElementById('btn-next');
      const isUltima = questaoAtual === total - 1;
      btnNext.textContent = isUltima ? 'Ver resultado →' : 'Avançar →';
      btnNext.disabled = selecionado === null;
    }

    function selecionarOpcao(idx) {
      respostas[questaoAtual] = idx;
      const total = testeAtual.questoes.length;

      renderQuestao();

      // Transição automática cronometrada para a questão seguinte
      setTimeout(() => {
        if (questaoAtual < total - 1) {
          questaoAtual++;
          renderQuestao();
        } else {
          finalizarTeste();
        }
      }, 350);
    }

    // ══════════════════════════════════════════════════════
    // INTERPRETAÇÃO E CÁLCULO DE RESULTADOS
    // ══════════════════════════════════════════════════════
    function calcularScore() {
      let score = 0;
      respostas.forEach((respIdx, qIdx) => {
        let valor = testeAtual.opcoes[respIdx].valor;
        if (testeAtual.invertidos && testeAtual.invertidos.includes(qIdx)) {
          const maxVal = testeAtual.opcoes[testeAtual.opcoes.length - 1].valor;
          valor = maxVal - valor;
        }
        score += valor;
      });
      return score;
    }

    function finalizarTeste() {
      const score = calcularScore();
      const result = testeAtual.interpretar(score);
      const maxScore = testeAtual.opcoes[testeAtual.opcoes.length - 1].valor * testeAtual.questoes.length;

      document.getElementById('resultado-box').innerHTML = `
        <div class="resultado-icon">${result.icone}</div>
        <div class="resultado-nivel">${result.nivel}</div>
        <div class="resultado-score">Pontuação: ${score} / ${maxScore} pontos</div>
