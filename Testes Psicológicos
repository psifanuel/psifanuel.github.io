  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <!-- EmailJS SDK -->
  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
  <style>
    :root {
      --cream: #f5f0e8;
      --warm-white: #faf8f3;
      --terra: #8b5e3c;
      --terra-light: #c4956a;
      --terra-dark: #5c3a1e;
      --sage: #7a9e7e;
      --sage-light: #b8d4ba;
      --sage-dark: #4a6b4e;
      --charcoal: #2d2926;
      --charcoal-mid: #5a5450;
      --gold: #c9a84c;
      --shadow: rgba(45, 41, 38, 0.12);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--warm-white);
      color: var(--charcoal);
      overflow-x: hidden;
    }

    /* ── NAVEGAÇÃO ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.2rem 4rem;
      background: rgba(250, 248, 243, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(139, 94, 60, 0.12);
      box-shadow: 0 4px 24px var(--shadow);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--terra-dark);
      text-decoration: none;
    }
    .nav-logo span { color: var(--terra); font-style: italic; }
    .nav-links { display: flex; gap: 2rem; align-items: center; list-style: none; }
    .nav-links a {
      font-size: 0.85rem; font-weight: 500; color: var(--charcoal-mid);
      text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; transition: color 0.2s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--terra); }
    .btn-nav {
      background: var(--terra); color: white !important;
      padding: 0.5rem 1.3rem; border-radius: 40px; transition: background 0.2s !important;
    }
    .btn-nav:hover { background: var(--terra-dark) !important; }

    /* ── CABEÇALHO DA PÁGINA ── */
    .page-header {
      padding: 8rem 4rem 3rem;
      background: linear-gradient(135deg, var(--cream) 0%, var(--warm-white) 100%);
      position: relative;
      overflow: hidden;
    }
    .page-header::after {
      content: 'ψ';
      position: absolute; right: 6rem; top: 50%;
      transform: translateY(-50%);
      font-family: 'Playfair Display', serif;
      font-size: 14rem; font-style: italic;
      color: rgba(139, 94, 60, 0.06);
      line-height: 1; pointer-events: none;
    }
    .page-header-inner { max-width: 700px; }
    .page-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--sage-light); color: var(--sage-dark);
      font-size: 0.75rem; font-weight: 500; letter-spacing: 0.06em;
      text-transform: uppercase; padding: 0.35rem 1rem;
      border-radius: 40px; margin-bottom: 1.5rem;
    }
    .page-header h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15; color: var(--charcoal); margin-bottom: 1rem;
    }
    .page-header h1 em { font-style: italic; color: var(--terra); }
    .page-header p {
      font-size: 1.05rem; color: var(--charcoal-mid);
      line-height: 1.7; font-weight: 300; max-width: 580px;
    }

    /* ── AVISO CLÍNICO ── */
    .aviso-clinico {
      background: rgba(139, 94, 60, 0.06);
      border-left: 4px solid var(--terra-light);
      padding: 1.2rem 2rem;
      margin: 0 4rem;
      border-radius: 0 12px 12px 0;
      display: flex; align-items: flex-start; gap: 1rem;
    }
    .aviso-clinico .aviso-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
    .aviso-clinico p { font-size: 0.88rem; color: var(--charcoal-mid); line-height: 1.6; }
    .aviso-clinico strong { color: var(--terra-dark); }

    /* ── CATEGORIAS DE FILTRAGEM ── */
    .categorias-section { padding: 3rem 4rem; }
    .cat-tabs {
      display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 3rem;
    }
    .cat-tab {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.6rem 1.2rem;
      background: white;
      border: 1.5px solid rgba(139, 94, 60, 0.15);
      border-radius: 40px;
      font-size: 0.85rem; font-weight: 500;
      color: var(--charcoal-mid);
      cursor: pointer; transition: all 0.2s;
    }
    .cat-tab:hover, .cat-tab.active {
      background: var(--terra); color: white;
      border-color: var(--terra);
      box-shadow: 0 4px 16px rgba(139, 94, 60, 0.25);
    }

    /* ── CARDS DE TESTES ── */
    .testes-lista { display: none; }
    .testes-lista.visible { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.2rem; }

    .teste-card {
      background: white;
      border-radius: 18px;
      padding: 1.8rem;
      border: 1.5px solid rgba(139, 94, 60, 0.1);
      cursor: pointer;
      transition: all 0.25s;
      position: relative;
      overflow: hidden;
    }
    .teste-card:hover {
      border-color: var(--terra-light);
      box-shadow: 0 16px 40px var(--shadow);
      transform: translateY(-4px);
    }
    .teste-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--terra), var(--terra-light));
      opacity: 0; transition: opacity 0.25s;
    }
    .teste-card:hover::before { opacity: 1; }

    .teste-card-icon { font-size: 2rem; margin-bottom: 1rem; }
    .teste-card-cat {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--terra); font-weight: 500; margin-bottom: 0.5rem;
    }
    .teste-card h3 { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--charcoal); margin-bottom: 0.5rem; }
    .teste-card p { font-size: 0.83rem; color: var(--charcoal-mid); line-height: 1.6; font-weight: 300; margin-bottom: 1.2rem; }
    .teste-card-footer {
      display: flex; justify-content: space-between; align-items: center;
      padding-top: 1rem; border-top: 1px solid var(--cream);
    }
    .teste-card-time { font-size: 0.75rem; color: var(--charcoal-mid); }
    .btn-iniciar {
      background: var(--cream); color: var(--terra-dark);
      border: 1.5px solid rgba(139, 94, 60, 0.2);
      padding: 0.4rem 1rem; border-radius: 30px;
      font-size: 0.8rem; font-weight: 500; cursor: pointer;
      transition: all 0.2s;
    }
    .btn-iniciar:hover { background: var(--terra); color: white; border-color: var(--terra); }

    /* ── MODAL DE TESTE ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0; z-index: 500;
      background: rgba(45, 41, 38, 0.7);
      backdrop-filter: blur(4px);
      align-items: center; justify-content: center;
      padding: 1rem;
    }
    .modal-overlay.open { display: flex; }

    .modal {
      background: white;
      border-radius: 24px;
      max-width: 680px; width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      position: relative;
      animation: modalIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.9) translateY(20px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    .modal-header {
      padding: 2rem 2rem 1.5rem;
      border-bottom: 1px solid var(--cream);
      position: sticky; top: 0; background: white; z-index: 1;
      border-radius: 24px 24px 0 0;
    }
    .modal-close {
      position: absolute; top: 1.2rem; right: 1.2rem;
      background: var(--cream); border: none; border-radius: 50%;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; font-size: 1rem; transition: all 0.2s;
    }
    .modal-close:hover { background: var(--terra); color: white; }

    .modal-body { padding: 2rem; }

    /* FASES DE EXECUÇÃO */
    .fase { display: none; }
    .fase.active { display: block; }

    /* FASE 0: FORMULÁRIO DE IDENTIFICAÇÃO */
    .form-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem; color: var(--charcoal); margin-bottom: 0.4rem;
    }
    .form-sub { font-size: 0.88rem; color: var(--charcoal-mid); margin-bottom: 1.8rem; line-height: 1.6; }

    .form-field { margin-bottom: 1.2rem; }
    .form-field label {
      display: block; font-size: 0.83rem; font-weight: 500;
      color: var(--charcoal); margin-bottom: 0.4rem;
      letter-spacing: 0.02em;
    }
    .form-field input, .form-field select {
      width: 100%; padding: 0.75rem 1rem;
      border: 1.5px solid rgba(139, 94, 60, 0.2);
      border-radius: 10px; font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem; color: var(--charcoal);
      background: var(--warm-white);
      transition: border-color 0.2s;
      outline: none;
    }
    .form-field input:focus, .form-field select:focus {
      border-color: var(--terra); background: white;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    /* FASE 1: PERGUNTAS */
    .progress-bar {
      height: 5px; background: var(--cream); border-radius: 99px;
      margin-bottom: 2rem; overflow: hidden;
    }
    .progress-fill {
      height: 100%; background: linear-gradient(90deg, var(--terra), var(--terra-light));
      border-radius: 99px; transition: width 0.4s ease;
    }
    .progress-label {
      font-size: 0.78rem; color: var(--charcoal-mid); text-align: right;
      margin-top: 0.4rem; margin-bottom: 1.5rem;
    }

    .questao-num {
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--terra); font-weight: 500; margin-bottom: 0.6rem;
    }
    .questao-texto {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; color: var(--charcoal); line-height: 1.5;
      margin-bottom: 1.5rem;
    }

    .opcoes { display: flex; flex-direction: column; gap: 0.6rem; }
    .opcao-btn {
      display: flex; align-items: center; gap: 1rem;
      padding: 0.9rem 1.2rem;
      background: var(--warm-white);
      border: 1.5px solid rgba(139, 94, 60, 0.12);
      border-radius: 12px;
      cursor: pointer; font-family: 'DM Sans', sans-serif;
      font-size: 0.93rem; color: var(--charcoal);
      text-align: left; transition: all 0.2s; width: 100%;
    }
    .opcao-btn:hover { border-color: var(--terra-light); background: rgba(139, 94, 60, 0.04); }
    .opcao-btn.selected { border-color: var(--terra); background: rgba(139, 94, 60, 0.06); color: var(--terra-dark); font-weight: 500; }
    .opcao-bullet {
      width: 28px; height: 28px; border-radius: 50%;
      background: white; border: 1.5px solid rgba(139, 94, 60, 0.2);
      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 700; transition: all 0.2s;
    }
    .opcao-btn.selected .opcao-bullet {
      background: var(--terra); border-color: var(--terra); color: white;
    }

    /* FASE 2: APRESENTAÇÃO DO RESULTADO */
    .resultado-box {
      text-align: center;
      padding: 1rem 0 0.5rem;
    }
    .resultado-icon { font-size: 3.5rem; margin-bottom: 1rem; }
    .resultado-nivel {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem; color: var(--charcoal); margin-bottom: 0.5rem;
    }
    .resultado-score {
      font-size: 0.85rem; color: var(--charcoal-mid); margin-bottom: 1.5rem;
    }
    .resultado-texto {
      background: var(--cream);
      border-radius: 14px;
      padding: 1.4rem;
      font-size: 0.93rem; color: var(--charcoal-mid);
      line-height: 1.7; font-weight: 300;
      text-align: left; margin-bottom: 1.5rem;
    }
    .cta-profissional {
      background: var(--charcoal);
      color: white;
      border-radius: 16px;
      padding: 1.6rem;
      text-align: left; margin-bottom: 1.5rem;
    }
    .cta-profissional h4 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; margin-bottom: 0.5rem;
    }
    .cta-profissional p { font-size: 0.85rem; color: rgba(255,255,255,0.7); line-height: 1.6; margin-bottom: 1rem; }
    .btn-whatsapp-resultado {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: #25D366; color: white;
      padding: 0.7rem 1.4rem; border-radius: 40px;
      font-size: 0.9rem; font-weight: 500; text-decoration: none;
      transition: all 0.2s;
    }
    .btn-whatsapp-resultado:hover { background: #1da851; transform: translateY(-1px); }

    .email-status {
      font-size: 0.78rem; color: var(--charcoal-mid);
      text-align: center; margin-top: 1rem;
      min-height: 1.2rem;
    }

    /* BOTÕES DE NAVEGAÇÃO INTERNA */
    .modal-footer {
      padding: 1.2rem 2rem;
      border-top: 1px solid var(--cream);
      display: flex; justify-content: space-between; align-items: center;
      position: sticky; bottom: 0; background: white;
      border-radius: 0 0 24px 24px;
    }
    .btn-action {
      padding: 0.75rem 1.8rem;
      border-radius: 40px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem; font-weight: 500;
      cursor: pointer; transition: all 0.2s; border: none;
    }
    .btn-back { background: var(--cream); color: var(--charcoal-mid); }
    .btn-back:hover { background: #e8e0d4; }
    .btn-next { background: var(--terra); color: white; box-shadow: 0 4px 16px rgba(139,94,60,0.3); }
    .btn-next:hover { background: var(--terra-dark); transform: translateY(-1px); }
    .btn-next:disabled { background: #ccc; box-shadow: none; cursor: not-allowed; transform: none; }

    /* FLUTUANTE WHATSAPP */
    .whatsapp-float {
      position: fixed; bottom: 2rem; right: 2rem; z-index: 200;
      background: #25D366; color: white;
      width: 58px; height: 58px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem; box-shadow: 0 6px 24px rgba(37,211,102,0.4);
      text-decoration: none; transition: all 0.25s;
    }
    .whatsapp-float:hover { transform: scale(1.1); }

    /* NOTIFICAÇÕES (TOAST) */
    .toast {
      position: fixed; top: 5rem; right: 2rem; z-index: 999;
      background: var(--charcoal); color: white;
      padding: 1rem 1.4rem; border-radius: 12px;
      font-size: 0.88rem; box-shadow: 0 8px 24px var(--shadow);
      transform: translateX(120%); transition: transform 0.3s;
      max-width: 300px;
    }
    .toast.show { transform: translateX(0); }

    @media (max-width: 900px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { gap: 1rem; }
      .page-header, .categorias-section { padding-left: 1.5rem; padding-right: 1.5rem; }
      .aviso-clinico { margin: 0 1.5rem; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
