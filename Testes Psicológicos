        teste_categoria: testeAtual.categoria,
        score: score,
        score_max: maxScore,
        nivel: result.nivel,
        data_hora: dataHora,
        respostas: respostasTexto
      };

      // Salvaguarda caso a chave pública padrão não tenha sido alterada
      if (EMAILJS_CONFIG.publicKey === 'SUA_PUBLIC_KEY') {
        console.warn('Configuração inicial do EmailJS pendente. Chave pública ausente.');
        document.getElementById('email-status').textContent = '⚠️ Configure o EmailJS para envio automático. Por enquanto, entre em contato via WhatsApp.';
        return;
      }

      emailjs.send(EMAILJS_CONFIG.serviceId, EMAILJS_CONFIG.templateId, params)
        .then(() => {
          document.getElementById('email-status').textContent = '✅ Resultado enviado com sucesso para análise profissional.';
        })
        .catch((err) => {
          console.error('Erro de submissão EmailJS:', err);
          document.getElementById('email-status').textContent = '❌ Erro no envio automático das respostas. Por favor, faça contato via WhatsApp.';
        });
    }

    // ══════════════════════════════════════════════════════
    // COMPONENTES AUXILIARES E INTERAÇÕES
    // ══════════════════════════════════════════════════════
    function mostrarToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3500);
    }

    // Fecha o modal ao clicar fora da área principal de conteúdo
    document.getElementById('modalOverlay').addEventListener('click', function(e) {
      if (e.target === this) fecharModal();
    });
  </script>
</body>
</html>
