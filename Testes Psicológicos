      templateId: 'SUA_TEMPLATE_ID'      // Email Templates (Substitua quando em produção)
    };

    // Inicialização segura do EmailJS caso tenha inserido uma Chave Pública válida
    if (EMAILJS_CONFIG.publicKey && EMAILJS_CONFIG.publicKey !== 'SUA_PUBLIC_KEY') {
      emailjs.init(EMAILJS_CONFIG.publicKey);
    }

    // ══════════════════════════════════════════════════════
    // BANCO DE DADOS DE TESTES (PT-BR)
    // ══════════════════════════════════════════════════════
    const TESTES = {
      gad7: {
